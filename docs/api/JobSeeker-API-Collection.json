{
  "info": {
    "name": "Vaidyog — Job Seeker API",
    "_postman_id": "vaidyog-jobseeker-api-v1",
    "description": "Complete API collection for Job Seekers on the Vaidyog healthcare jobs platform.\n\n**Auth:** After calling Login or Register, the token is automatically saved to `{{token}}`.\n\nAll protected routes require: `Authorization: Bearer {{token}}`",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000", "type": "string" },
    { "key": "token",    "value": "",                     "type": "string" },
    { "key": "job_id",   "value": "",                     "type": "string" },
    { "key": "app_id",   "value": "",                     "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": ["var res = pm.response.json();", "if (res.data && res.data.token) pm.collectionVariables.set('token', res.data.token);"], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Priya Sharma\",\n  \"email\": \"priya.sharma@example.com\",\n  \"phone\": \"9876543210\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/jobseeker/register", "host": ["{{base_url}}"], "path": ["api", "jobseeker", "register"] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["var res = pm.response.json();", "if (res.data && res.data.token) pm.collectionVariables.set('token', res.data.token);"], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"priya.sharma@example.com\",\n  \"password\": \"password123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/api/jobseeker/login", "host": ["{{base_url}}"], "path": ["api", "jobseeker", "login"] }
          }
        },
        {
          "name": "Me (Current User)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/jobseeker/me", "host": ["{{base_url}}"], "path": ["api", "jobseeker", "me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/api/jobseeker/logout", "host": ["{{base_url}}"], "path": ["api", "jobseeker", "logout"] }
          }
        }
      ]
    },
